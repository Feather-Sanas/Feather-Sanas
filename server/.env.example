# Sanas Remote SDK credentials — get these from https://developer.sanas.ai
# Copy to ".env" and fill in. NEVER commit the real .env.
SANAS_ENDPOINT=sip.sanas.ai

# Auth: SANAS_API_KEY (developer-console key, e.g. sk_...) is preferred and takes
# precedence. Account-based auth is the fallback if the API key is unset.
SANAS_API_KEY=
# SANAS_ACCOUNT_ID=your_account_id
# SANAS_ACCOUNT_SECRET=your_account_secret

# Model to run on uploaded clips (Speech Enhancement by default).
# Options: SE2.2 | SE2.1 | VI_G_NC3.0 | AGENTIC_VI_G_NC | AGENTIC_ST_NC | AGENTIC_VI_GT_NC
SANAS_MODEL=SE2.2

# Frame size in ms for ProcessSamples (the SDK example uses 20ms).
SANAS_FRAME_MS=20
# Silent frames fed after input to flush the pipeline latency tail.
SANAS_DRAIN_MS=800
SANAS_SECURE_MEDIA=false

# The engine runs in real time, so wall-clock ~= clip duration. Uploads are
# trimmed to this many seconds so a request can't hang for minutes.
SAN_MAX_CLIP_S=30

# --- Claude (San's conversational brain) ---
# Add your Anthropic API key to route chat through Claude (streamed token-by-token).
# Without it, San uses its deterministic rule-based engine (the UI works either way).
ANTHROPIC_API_KEY=
# Chat model. Sonnet is a good default for low-latency chat; set claude-opus-4-8
# for maximum quality.
SAN_LLM_MODEL=claude-sonnet-4-6
